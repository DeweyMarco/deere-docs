{
  "openapi": "3.0.0",
  "info": {
    "title": "Operations Center — Map Layers API",
    "description": "Contribute **Map Layers** to **John Deere Operations Center** so growers see geospatial information per field—management zones, imagery, prescriptions, soil maps, and more. Map Layers are grouped under a **Map Layer Summary** (context and Markdown text). Each **Map Layer** holds one image (or processed shapefile), optional **legend** ranges, **extent**, and **metadata**.\n\nResponses use **Axiom v3** JSON (`application/vnd.deere.axiom.v3+json`) and **CollectionPage** (`total`, `links`, `values`) where applicable.\n\n**Paging:** Use `itemLimit` (10–100, multiples of 10) and `pageOffset` on list endpoints.\n\n**Markdown:** Map Layer Summary and Map Layer text fields support a **subset of Markdown** (see platform Markdown documentation).\n\n**eTags:** **GET** `/platform/organizations/{orgId}/fields/{id}/mapLayerSummaries`, **GET** `/platform/mapLayerSummaries/{id}/mapLayers`, and **GET** `/platform/mapLayers/{id}/fileResources` **do not** support `x-deere-signature` eTags.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://sandboxapi.deere.com",
      "description": "Sandbox platform API (`/platform/…` paths)"
    }
  ],
  "tags": [
    {
      "name": "Map layer summaries",
      "description": "Summaries group Map Layers for a field and carry Markdown overview text."
    },
    {
      "name": "Map layers",
      "description": "Individual map layer resources (one image per layer) and PNG extraction."
    },
    {
      "name": "File resources",
      "description": "Reserve, upload, download, and delete binary files (PNG, GeoTIFF, ZIP shapefile) for a Map Layer."
    }
  ],
  "components": {
    "securitySchemes": {
      "OAuth2AuthorizationCode": {
        "type": "oauth2",
        "description": "Three-legged OAuth 2.0 (authorization code) for John Deere Precision Tech platform APIs. Scopes **`ag1`**, **`ag2`**, and **`ag3`** are used by these endpoints. Request **`offline_access`** for refresh tokens.",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://signin.johndeere.com/oauth2/aus78tnlaysMraFhC1t7/v1/authorize",
            "tokenUrl": "https://signin.johndeere.com/oauth2/aus78tnlaysMraFhC1t7/v1/token",
            "refreshUrl": "https://signin.johndeere.com/oauth2/aus78tnlaysMraFhC1t7/v1/token",
            "scopes": {
              "ag1": "Locations Access Level 1 — view locations and map layers",
              "ag2": "Locations Access Level 2 — analyze production data (summaries list/read)",
              "ag3": "Locations Access Level 3 — manage locations and production data (create/update/delete)",
              "offline_access": "Request a refresh token"
            }
          }
        }
      }
    },
    "schemas": {
      "Link": {
        "type": "object",
        "description": "Hypermedia link (`@type` **Link** when present).",
        "properties": {
          "@type": { "type": "string", "example": "Link" },
          "rel": { "type": "string", "example": "self" },
          "uri": { "type": "string", "format": "uri" }
        }
      },
      "CollectionPage": {
        "type": "object",
        "description": "Paged collection wrapper (`total`, `links`, `values`).",
        "properties": {
          "total": { "type": "integer", "example": 2 },
          "links": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Link" }
          },
          "values": {
            "type": "array",
            "items": { "type": "object", "additionalProperties": true }
          }
        }
      },
      "MetadataDetail": {
        "type": "object",
        "description": "Key/value metadata; **value** supports limited Markdown.",
        "properties": {
          "name": { "type": "string", "example": "time" },
          "value": { "type": "string", "example": "Friday, June 29, 2018 (CDT)" }
        }
      },
      "LegendRange": {
        "type": "object",
        "description": "Min inclusive, max exclusive range for legend coloring.",
        "properties": {
          "label": { "type": "string", "example": "Some Label" },
          "minimum": { "type": "number", "format": "double", "example": 0.0 },
          "maximum": { "type": "number", "format": "double", "example": 100.0 },
          "hexColor": { "type": "string", "example": "#0BA74A" },
          "percent": { "type": "number", "format": "double", "example": 0.13 }
        }
      },
      "ExtentDetails": {
        "type": "object",
        "properties": {
          "minimumLatitude": { "type": "number", "format": "double", "example": 41.76073 },
          "maximumLatitude": { "type": "number", "format": "double", "example": 41.771366 },
          "minimumLongitude": { "type": "number", "format": "double", "example": -93.488106 },
          "maximumLongitude": { "type": "number", "format": "double", "example": -93.4837 }
        }
      },
      "MapLayerSummaryResource": {
        "type": "object",
        "description": "A Map Layer Summary resource (structure follows live Axiom responses).",
        "additionalProperties": true,
        "example": {
          "@type": "MapLayerSummary",
          "id": "335c06b6-f645-42fd-99f6-74c84f633d46",
          "text": "## NDVI overview\nSatellite pass from 2024-06-15.",
          "type": "SATELLITE"
        }
      },
      "CreateMapLayerSummaryRequest": {
        "type": "object",
        "description": "Body for **POST** `/platform/organizations/{orgId}/fields/{id}/mapLayerSummaries`. Markdown supported on summary text fields per API.",
        "additionalProperties": true,
        "example": {
          "@type": "MapLayerSummary",
          "text": "## Field summary\nUse **Markdown** for context.",
          "type": "SATELLITE"
        }
      },
      "MapLayerResource": {
        "type": "object",
        "description": "A single Map Layer (Axiom). **status** may be `VALID`, `INVALID`, `QUEUED`, or `NO_FILE_RESOURCE`.",
        "additionalProperties": true,
        "example": {
          "@type": "MapLayer",
          "id": "c303004d-beb8-471d-b144-c44bb5318e55",
          "type": "PRESCRIPTION",
          "status": "VALID"
        }
      },
      "CreateMapLayerRequest": {
        "type": "object",
        "description": "Body for **POST** `/platform/mapLayerSummaries/{id}/mapLayers`. Markdown supported on text fields per API.",
        "additionalProperties": true,
        "example": {
          "@type": "MapLayer",
          "text": "## Layer details\nLegend and notes.",
          "type": "PRESCRIPTION"
        }
      },
      "FileResourceResource": {
        "type": "object",
        "description": "File Resource metadata and links (upload target, MIME type, processing status).",
        "additionalProperties": true
      },
      "CreateFileResourceRequest": {
        "type": "object",
        "description": "Body for **POST** `/platform/mapLayers/{id}/fileResources`. MIME type selects processing (PNG, GeoTIFF, ZIP shapefile).",
        "additionalProperties": true,
        "example": {
          "@type": "FileResource",
          "mimeType": "image/png"
        }
      },
      "ErrorBody": {
        "type": "object",
        "description": "Error payload for error responses.",
        "additionalProperties": true
      }
    }
  },
  "paths": {
    "/platform/organizations/{orgId}/fields/{id}/mapLayerSummaries": {
      "get": {
        "tags": ["Map layer summaries"],
        "operationId": "listFieldMapLayerSummaries",
        "summary": "List Map Layer Summaries",
        "description": "Lists **all Map Layer Summaries** for the specified **field**.\n\n**Note:** This API **does not** support eTags.\n\n**OAuth scope:** `ag2`\n\n**Request URL:** `GET https://sandboxapi.deere.com/platform/organizations/{orgId}/fields/{id}/mapLayerSummaries`",
        "security": [{ "OAuth2AuthorizationCode": ["ag2"] }],
        "parameters": [
          {
            "name": "orgId",
            "in": "path",
            "required": true,
            "description": "Operations Center organization id.",
            "schema": { "type": "string", "example": "283480" }
          },
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Field id.",
            "schema": { "type": "string", "example": "5513840f-1a8d-4dd4-aff2-3020d308d154" }
          },
          {
            "name": "itemLimit",
            "in": "query",
            "required": false,
            "description": "Page size: multiples of **10**, max **100**.",
            "schema": { "type": "integer", "minimum": 10, "maximum": 100, "multipleOf": 10, "example": 50 }
          },
          {
            "name": "pageOffset",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "minimum": 0, "example": 0 }
          },
          {
            "name": "showLinks",
            "in": "query",
            "required": false,
            "schema": { "type": "string", "example": "none" }
          },
          {
            "name": "Accept",
            "in": "header",
            "required": false,
            "schema": { "type": "string", "example": "application/vnd.deere.axiom.v3+json" }
          },
          {
            "name": "Accept-Encoding",
            "in": "header",
            "required": false,
            "schema": { "type": "string", "enum": ["gzip"] }
          }
        ],
        "x-codeSamples": [
          {
            "lang": "bash",
            "label": "cURL",
            "source": "curl --request GET \\\n  --url 'https://sandboxapi.deere.com/platform/organizations/283480/fields/5513840f-1a8d-4dd4-aff2-3020d308d154/mapLayerSummaries?itemLimit=50&pageOffset=0' \\\n  --header 'Authorization: Bearer <access_token>' \\\n  --header 'Accept: application/vnd.deere.axiom.v3+json' \\\n  --header 'Accept-Encoding: gzip'"
