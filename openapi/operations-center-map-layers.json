    "/platform/mapLayers/{id}": {
      "get": {
        "tags": ["Map layers"],
        "operationId": "getMapLayerOrImage",
        "summary": "View a Map Layer or extract PNG image",
        "description": "Content negotiation:\n\n- **`Accept: application/vnd.deere.axiom.v3+json`** — returns the **Map Layer** resource JSON.\n- **`Accept: image/png`** or **`Accept: application/octet-stream`** — returns the **processed image** for the layer (PNG), regardless of original upload format.\n\n**OAuth scope:** `ag1`\n\n**Request URL:** `GET https://sandboxapi.deere.com/platform/mapLayers/{id}`",
        "security": [{ "OAuth2AuthorizationCode": ["ag1"] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "Map Layer id.",
            "schema": { "type": "string", "example": "c303004d-beb8-471d-b144-c44bb5318e55" }
          },
          {
            "name": "Accept",
