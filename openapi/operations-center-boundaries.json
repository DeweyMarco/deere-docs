      },
      "post": {
        "tags": ["Boundaries"],
        "operationId": "createBoundary",
        "summary": "Create a Field Boundary",
        "description": "Creates a **field boundary** with a geometry collection for the field.\n\n**Content-Type:** `application/vnd.deere.axiom.v3+json`\n\n**OAuth scope:** `ag3`\n\n**Request URL:** `POST https://sandboxapi.deere.com/platform/organizations/{orgId}/fields/{fieldId}/boundaries`",
        "security": [{ "OAuth2AuthorizationCode": ["ag3"] }],
        "parameters": [
          {
            "name": "orgId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "example": "283480" }
          },
          {
            "name": "fieldId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "example": "c303004d-beb8-471d-b144-c44bb5318e56" }
          },
          { "$ref": "#/components/parameters/ContentTypeAxiomV3" },
          { "$ref": "#/components/parameters/AcceptAxiomV3" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/vnd.deere.axiom.v3+json": {
              "schema": { "$ref": "#/components/schemas/BoundaryCreateRequest" }
            }
          }
        },
        "x-codeSamples": [
          {
            "lang": "bash",
            "label": "cURL",
            "source": "curl --request POST \\\n  --url 'https://sandboxapi.deere.com/platform/organizations/283480/fields/c303004d-beb8-471d-b144-c44bb5318e56/boundaries' \\\n  --header 'Authorization: Bearer <access_token>' \\\n  --header 'Accept: application/vnd.deere.axiom.v3+json' \\\n  --header 'Content-Type: application/vnd.deere.axiom.v3+json' \\\n  --data '{\"name\":\"North 80\",\"active\":true,\"multipolygon\":{\"polygons\":[{\"rings\":[{\"type\":\"exterior\",\"points\":[{\"lat\":41.1,\"lon\":-93.6},{\"lat\":41.11,\"lon\":-93.6},{\"lat\":41.11,\"lon\":-93.59},{\"lat\":41.1,\"lon\":-93.6}]}]}]}}'"
          }
        ],
        "responses": {
          "200": {
            "description": "Created or returned boundary (per platform).",
            "content": {
              "application/vnd.deere.axiom.v3+json": {
                "schema": { "$ref": "#/components/schemas/BoundaryResource" }
              }
            }
          },
          "201": {
            "description": "Created.",
            "content": {
              "application/vnd.deere.axiom.v3+json": {
                "schema": { "$ref": "#/components/schemas/BoundaryResource" }
              }
            }
          },
          "400": {
            "description": "Bad request (invalid geometry or payload).",
            "content": {
              "application/vnd.deere.axiom.v3+json": {
                "schema": { "$ref": "#/components/schemas/ErrorBody" }
              }
            }
          },
          "401": {
            "description": "Unauthorized.",
            "content": {
              "application/vnd.deere.axiom.v3+json": {
                "schema": { "$ref": "#/components/schemas/ErrorBody" }
              }
            }
          },
          "403": {
            "description": "Forbidden.",
            "content": {
              "application/vnd.deere.axiom.v3+json": {
                "schema": { "$ref": "#/components/schemas/ErrorBody" }
              }
            }
          }
        }
      }
    },
