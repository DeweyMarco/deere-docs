    "/platform/fieldOperations/{operationId}/boundary": {
      "get": {
        "tags": ["Boundaries"],
        "operationId": "generateBoundaryFromFieldOperation",
        "summary": "Generate a Boundary from a Field Operation",
        "description": "Returns a **generated boundary** that surrounds the area worked by the **field operation**. Gaps in coverage appear as **interior** rings. Use the response to adjust the name, remove unwanted interiors, then **POST** the boundary to persist it.\n\n**HTTP 400** may be returned when:\n- The field already has an **active** boundary (prefer the existing boundary).\n- The field was **merged** (the operation may cover only part of the merged field).\n\n**OAuth scope:** `ag2`\n\n**Request URL:** `GET https://sandboxapi.deere.com/platform/fieldOperations/{operationId}/boundary`",
        "security": [{ "OAuth2AuthorizationCode": ["ag2"] }],
        "parameters": [
          {
            "name": "operationId",
            "in": "path",
            "required": true,
            "description": "Field operation id.",
            "schema": { "type": "string", "example": "a1b2c3d4-e5f6-7890-abcd-ef1234567890" }
          },
