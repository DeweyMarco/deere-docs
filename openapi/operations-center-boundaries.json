      },
      "put": {
        "tags": ["Boundaries"],
        "operationId": "updateBoundary",
        "summary": "Update a Boundary",
        "description": "Updates a **field boundary**. The body must include **name**, **active**, **irrigated**, **sourceType**, and **multipolygons**. If **active** is set to true, other boundaries on the same field become inactive. A license may be required to set **sourceType** to a value other than **External**.\n\n**Content-Type:** `application/vnd.deere.axiom.v3+json`\n\n**OAuth scope:** `ag3`\n\n**Request URL:** `PUT https://sandboxapi.deere.com/platform/organizations/{orgId}/fields/{fieldId}/boundaries/{boundaryId}`",
        "security": [{ "OAuth2AuthorizationCode": ["ag3"] }],
        "parameters": [
          {
            "name": "orgId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "example": "283480" }
          },
          {
            "name": "fieldId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "example": "c303004d-beb8-471d-b144-c44bb5318e56" }
          },
          {
            "name": "boundaryId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "example": "c303004d-beb8-471d-b144-c44bb5318e55" }
          },
          { "$ref": "#/components/parameters/ContentTypeAxiomV3" },
          { "$ref": "#/components/parameters/AcceptAxiomV3" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/vnd.deere.axiom.v3+json": {
              "schema": { "$ref": "#/components/schemas/BoundaryUpdateRequest" }
            }
          }
        },
        "x-codeSamples": [
          {
            "lang": "bash",
            "label": "cURL",
            "source": "curl --request PUT \\\n  --url 'https://sandboxapi.deere.com/platform/organizations/283480/fields/c303004d-beb8-471d-b144-c44bb5318e56/boundaries/c303004d-beb8-471d-b144-c44bb5318e55' \\\n  --header 'Authorization: Bearer <access_token>' \\\n  --header 'Accept: application/vnd.deere.axiom.v3+json' \\\n  --header 'Content-Type: application/vnd.deere.axiom.v3+json' \\\n  --data '{\"name\":\"North 80\",\"active\":true,\"irrigated\":false,\"sourceType\":\"External\",\"multipolygons\":[{\"rings\":[{\"type\":\"exterior\",\"points\":[{\"lat\":41.1,\"lon\":-93.6},{\"lat\":41.11,\"lon\":-93.6},{\"lat\":41.11,\"lon\":-93.59},{\"lat\":41.1,\"lon\":-93.6}]}]}]}'"
          }
        ],
        "responses": {
          "200": {
            "description": "Updated boundary.",
            "content": {
              "application/vnd.deere.axiom.v3+json": {
                "schema": { "$ref": "#/components/schemas/BoundaryResource" }
              }
            }
          },
          "400": {
