    },
    "/platform/assets/{assetId}/locations": {
      "get": {
        "tags": ["Asset locations"],
        "operationId": "listAssetLocations",
        "summary": "Get all locations for an asset",
        "description": "Returns **location history** for the asset. Optional **startDate** and **endDate** bound the time range.\n\n**Note:** This API **does not** support eTags (**`x-deere-signature`**).\n\n**OAuth scope:** `eq1`",
        "security": [{ "OAuth2AuthorizationCode": ["eq1"] }],
        "parameters": [
          {
            "name": "assetId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "example": "a1b2c3d4-e5f6-7890-abcd-ef1234567890" }
          },
          {
            "name": "startDate",
            "in": "query",
            "required": false,
            "description": "Range start (ISO 8601).",
            "schema": { "type": "string", "format": "date-time", "example": "2024-06-01T00:00:00Z" }
          },
          {
            "name": "endDate",
            "in": "query",
            "required": false,
            "description": "Range end (ISO 8601).",
            "schema": { "type": "string", "format": "date-time", "example": "2024-06-30T23:59:59Z" }
          },
          {
            "name": "itemLimit",
