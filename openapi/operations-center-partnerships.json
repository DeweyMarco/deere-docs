      "post": {
        "tags": ["Partnerships"],
        "operationId": "assignPartnershipPermissions",
        "summary": "Request or assign permissions",
        "description": "Updates a partner permission or requests a permission from a partner. Assign relevant permission types to enable **file sharing** within the partnership.\n\n**Pending partnerships:** after **POST** `/platform/partnerships`, the **`partnershipId`** for permission calls may be the **`contactInvitationId`**; use that value as **`{token}`** in the path when applicable.\n\n**OAuth scope:** **`org2`**\n\n**Request URL:** `POST https://sandboxapi.deere.com/platform/partnerships/{token}/permissions`",
        "security": [
          {
            "OAuth2AuthorizationCode": ["org2"]
          }
        ],
        "parameters": [
          {
            "name": "token",
            "in": "path",
            "required": true,
            "description": "Partnership token or contact invitation id for pending requests.",
            "schema": {
              "type": "string",
              "example": "abc123-partnership-token"
            }
          },
          {
            "name": "Accept",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string",
              "default": "application/vnd.deere.axiom.v3+json"
            }
          },
          {
            "name": "Content-Type",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string",
              "default": "application/vnd.deere.axiom.v3+json"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/vnd.deere.axiom.v3+json": {
              "schema": {
                "$ref": "#/components/schemas/AssignPartnershipPermissionsBody"
              }
            }
          }
        },
        "x-codeSamples": [
          {
            "lang": "bash",
            "label": "cURL",
            "source": "curl --request POST \\\n  --url 'https://sandboxapi.deere.com/platform/partnerships/abc123-partnership-token/permissions' \\\n  --header 'Authorization: Bearer <access_token>' \\\n  --header 'Accept: application/vnd.deere.axiom.v3+json' \\\n  --header 'Content-Type: application/vnd.deere.axiom.v3+json' \\\n  --data '{\"permissions\":[{\"permissionId\":3001,\"granted\":true}]}'"
          }
        ],
        "responses": {
          "200": {
            "description": "Permissions updated.",
            "content": {
              "application/vnd.deere.axiom.v3+json": {
                "schema": {
                  "$ref": "#/components/schemas/PartnershipPermissions"
                }
              }
            }
          },
          "204": {
