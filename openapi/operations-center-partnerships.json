        "operationId": "listPartnershipPermissions",
        "summary": "View permissions in a partnership",
        "description": "Returns permissions one partner has assigned the other. The response links to the **assign permissions** resource for updates. **This API does not support eTags.**\n\n**OAuth scope:** **`org1`**\n\n**Request URL:** `GET https://sandboxapi.deere.com/platform/partnerships/{token}/permissions`",
        "security": [
          {
            "OAuth2AuthorizationCode": ["org1"]
          }
        ],
        "parameters": [
          {
            "name": "token",
            "in": "path",
            "required": true,
            "description": "Partnership or pending invitation token (use **contactInvitation** id for pending partnership permission requests per product notes).",
            "schema": {
              "type": "string",
              "example": "abc123-partnership-token"
            }
          },
          {
            "name": "Accept",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string",
              "default": "application/vnd.deere.axiom.v3+json"
            }
          }
        ],
        "x-codeSamples": [
          {
            "lang": "bash",
