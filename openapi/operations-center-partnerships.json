            "source": "curl --request GET \\\n  --url 'https://sandboxapi.deere.com/platform/partnerships/abc123-partnership-token' \\\n  --header 'Authorization: Bearer <access_token>' \\\n  --header 'Accept: application/vnd.deere.axiom.v3+json'"
          }
        ],
        "responses": {
          "200": {
            "description": "Partnership resource.",
            "content": {
              "application/vnd.deere.axiom.v3+json": {
                "schema": {
                  "$ref": "#/components/schemas/Partnership"
                }
              }
            }
          },
          "401": {
