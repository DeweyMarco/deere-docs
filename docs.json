{
    "$schema": "https://mintlify.com/docs.json",
    "name": "John Deere",
    "theme": "palm",
    "logo": {
      "light": "/logo/john-deere.png",
      "dark": "/logo/john-deere.png",
      "href": "/"
    },
    "colors": {
      "primary": "#367C2B",
      "light": "#FFDE00",
      "dark": "#367C2B"
    },
    "api": {
      "openapi": "openapi.json",
      "playground": {
        "display": "interactive"
      },
      "examples": {
        "languages": ["bash"]
      }
    },
    "navigation": {
        "global": {
            "anchors": [
                {
                    "anchor": "Home",
                    "icon": "house",
                    "href": "/"
                }
            ]
        },
        "tabs": [
            {
                "tab": "Dealer Solutions",
                "icon": "square-terminal",
                "pages": [
                    "dealer_solutions/dealer_data_feed",
                    {
                        "group": "Dealer Data Feed API",
                        "openapi": "openapi.json",
                        "pages": [
                            "GET /caas/v1/ddf/categories",
                            "GET /caas/v1/ddf/products"
                        ]
                    }
                ]
            },
            {
                "tab": "Financial",
                "icon": "square-terminal",
                "pages": [
                    "financial/index"
                ]
            },
            {
                "tab": "Precision Tech",
                "icon": "square-terminal",
                "pages": [
                    "precision_tech/index"
                ]
            },
            {
                "tab": "Supply Chain",
                "icon": "square-terminal",
                "pages": [
                    "supply_chain/index"
                ]
            }
        ]
    }
}